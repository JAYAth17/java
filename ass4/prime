import java.util.Scanner;
class prime {
public static void main(String [] args){
Scanner s = new Scanner(System.in);
System.out.print("Enter the number");
int n = s.nextInt();
int count =0;
for(int i=1;i<=n;i++){
if(i%n==0)
count++;}
if(count==2){
System.out.print(n +" is prime");
}
else
{
System.out.print( n+ " is not prime");
}
}
}
